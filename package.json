    "signalk-node-server-plugin",
    "signalk-category-instruments",
    "meshcore",
    "meshtastic",
    "lora",
    "mesh",
    "telemetry",
    "ais",
    "freeboard-sk"
  ],
  "homepage": "https://github.com/Banzarykey/signalk-meshcore#readme",
  "bugs": {
    "url": "https://github.com/Banzarykey/signalk-meshcore/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Banzarykey/signalk-meshcore.git"
  },
  "license": "GPL-3.0",
  "author": "Banzarykey",
  "type": "commonjs",
  "main": "index.js",
  "files": [
    "index.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@liamcottle/meshcore.js": "^1.13.0"
  },
  "peerDependencies": {
    "@signalk/server-api": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@signalk/server-api": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
